{
  "name": "content-vault",
  "version": "0.1.0",
  "private": true,
  "description": "Local personal content management tool for family travel media",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "npm run build:client",
    "build:client": "vite build --config client/vite.config.js",
    "import:dayone": "node scripts/import-dayone.js",
    "start": "node server/index.js",
    "start:local": "npm run build:client && npm start"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.821.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0",
    "exif-reader": "^2.0.3",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
